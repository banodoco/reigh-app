  "findings": [
    {
      "dimension": "design_coherence",
      "identifier": "orchestrator_hook_surface_bloat",
      "summary": "Core lightbox/timeline hooks act as god-orchestrators with oversized input/output contracts.",
      "related_files": [
        "src/shared/components/MediaLightbox/hooks/useSharedLightboxState.ts",
        "src/tools/travel-between-images/components/Timeline/hooks/useTimelineOrchestrator.ts"
      ],
      "evidence": [
        "`UseSharedLightboxStateProps` composes six concern-specific interfaces and returns a similarly broad multi-section object, then `useSharedLightboxState` still wires all those concerns directly (`useSharedLightboxState.ts:127-138`, `:144-218`, `:631-735`).",
        "`useTimelineOrchestrator` declares a very large return contract and manages unrelated responsibilities (drag/drop, zooming, selection, pending frames, structure video placement, local modal state) in one hook (`useTimelineOrchestrator.ts:54-139`, `:163-520`)."
      ],
      "suggestion": "Split both hooks into explicit domain adapters with narrow contracts (for example: `timelineInteractionModel`, `timelineViewportModel`, `timelineStructureVideoModel`; and `lightboxVariantModel`, `lightboxShotModel`, `lightboxActionsModel`). Keep a thin composition layer that only combines already-stable sub-models and pass these grouped models to consumers instead of wide prop bags.",
      "confidence": "high",
      "impact_scope": "subsystem",
      "fix_scope": "architectural_change",
      "root_cause_cluster": "state_orchestration_without_bounded_context"
    },
    {
      "dimension": "design_coherence",
      "identifier": "generation_settings_translation_churn",
      "summary": "Travel generation settings are repeatedly remapped across layers instead of sharing one canonical contract.",
      "related_files": [
        "src/tools/travel-between-images/components/ShotEditor/controllers/useGenerationController.ts",
        "src/tools/travel-between-images/components/ShotEditor/services/generateVideo/types.ts",
        "src/tools/travel-between-images/components/ShotEditor/services/generateVideo/requestBody.ts"
      ],
      "evidence": [
        "`GenerationControllerJoinSettings`/`GenerationControllerMotionSettings` are manually mapped to `BatchGenerationRequest` and stitch config (`useGenerationController.ts:28-68`, `:88-153`).",
        "Service layer defines separate parameter interfaces (`MotionParams`, `GenerationParams`, `SeedParams`, `BuildTravelRequestBodyParams`) and then remaps those again into snake_case transport fields (`types.ts:80-114`, `requestBody.ts:21-73`)."
      ],
      "suggestion": "Introduce a single canonical `TravelGenerationCommand` (domain-level) shared by controller and service, with one serializer at the API boundary. Replace the current stepwise manual mapping with typed conversion helpers generated from that contract, so field additions/removals are changed once.",
      "confidence": "high",
      "impact_scope": "module",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "manual_mapping_without_shared_contract"
    },
    {
      "dimension": "design_coherence",
      "identifier": "ui_container_responsibility_mixing",
      "summary": "Large UI components mix rendering with data orchestration and workflow side effects.",
      "related_files": [
        "src/shared/components/MediaGalleryItem.tsx",
        "src/shared/components/ShotImageManager/ShotImageManagerDesktop.tsx",
        "src/shared/components/TasksPane/TasksPane.tsx"
      ],
      "evidence": [
        "`MediaGalleryItem` is responsible for render logic plus task lookup/prefetch/type resolution/share/shot-creation orchestration in one component (`MediaGalleryItem.tsx:128-203`).",
        "`ShotImageManagerDesktop` combines display logic with tick lifecycle timers, task prefetching, pending-image routing, and scrubbing orchestration (`ShotImageManagerDesktop.tsx:101-177`, `:185-220`).",
        "`TasksPane` combines pane shell rendering with persistence policy (`sessionStorage`), task query composition, optimistic counting, cancellation orchestration, and lightbox/shot wiring (`TasksPane.tsx:68-83`, `:117-169`, `:201-220`)."
      ],
      "suggestion": "Move orchestration concerns into dedicated page-level view-model hooks (`useTasksPaneModel`, `useMediaGalleryItemModel`, `useShotImageManagerModel`) and keep component files primarily declarative. Enforce a convention: component files should not perform cross-resource query composition or persistence policy directly.",
      "confidence": "medium",
      "impact_scope": "subsystem",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "state_orchestration_without_bounded_context"
    },
    {
      "dimension": "error_consistency",
      "identifier": "xhr_async_errors_escape_local_handler",
      "summary": "Download path throws in XHR callbacks that bypass the local error pipeline",
      "related_files": [
        "src/shared/components/MediaGallery/hooks/useMediaGalleryActions.ts",
        "src/shared/components/CreditsManagement/hooks/useTaskLogDownload.ts"
      ],
      "evidence": [
        "useMediaGalleryActions.ts:217-251 throws inside `xhr.onload`/`xhr.onerror`; those callbacks run after the outer try block and are not caught by catch at :254-256.",
        "useMediaGalleryActions.ts:257 clears `setDownloadingImageId(null)` in finally immediately after `xhr.send()` (:253), so UI reports completion even if request later fails.",
        "In contrast, useTaskLogDownload.ts uses awaited calls inside one try/catch and routes errors through `handleError` at :127-128."
      ],
      "suggestion": "Wrap XHR in a Promise and `await` it (or replace with `fetch` + await) so failures are caught in one catch path; move `setDownloadingImageId(null)` to after awaited completion/failure.",
      "confidence": "high",
      "impact_scope": "module",
      "fix_scope": "single_edit",
      "root_cause_cluster": "async_error_channel_drift"
    },
    {
      "dimension": "error_consistency",
      "identifier": "silent_persistence_failures",
      "summary": "Persistence hooks silently drop DB failures and return fallback values",
      "related_files": [
        "src/shared/components/MediaLightbox/hooks/inpainting/useEditModePersistence.ts",
        "src/shared/components/GenerationDetails/useGenerationDetails.ts"
      ],
      "evidence": [
        "useEditModePersistence.ts:37-39 catches load errors and returns null with no logging/context.",
        "useEditModePersistence.ts:76 catches save errors and intentionally ignores them, hiding failed writes.",
        "useGenerationDetails.ts:46-50 catches JSON parse failure and returns empty images, masking malformed task payloads."
      ],
      "suggestion": "Standardize these catches to call `handleError` with non-toast telemetry context (and include identifiers like generationId/taskId), while still returning safe fallbacks for UX.",
      "confidence": "high",
      "impact_scope": "subsystem",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "silent_fallback_over_logging"
    },
    {
      "dimension": "error_consistency",
      "identifier": "boundary_logging_strategy_mismatch",
      "summary": "Error boundaries use inconsistent capture strategy, reducing incident traceability",
      "related_files": [
        "src/shared/components/ChunkLoadErrorBoundary.tsx",
        "src/app/components/error/AppErrorBoundary.tsx"
      ],
      "evidence": [
        "ChunkLoadErrorBoundary.tsx:48-53 triggers reload on catch without recording error details.",
        "AppErrorBoundary.tsx:40-49 logs structured context via handleError before rendering fallback.",
        "Both are top-level crash-recovery boundaries but only one preserves diagnostic context."
      ],
      "suggestion": "Apply a shared boundary error helper so both boundaries log normalized context before recovery actions (reload/fallback), with a consistent `context` naming convention.",
      "confidence": "high",
      "impact_scope": "subsystem",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "error_boundary_policy_drift"
    },
    {
      "dimension": "error_consistency",
      "identifier": "media_play_rejections_swallowed",
      "summary": "play() promise failures are ignored in multiple media surfaces",
      "related_files": [
        "src/pages/Home/components/panes/PhilosophyPane.tsx",
        "src/shared/components/MediaLightbox/components/VideoEditModeDisplay.tsx",
        "src/shared/components/HoverScrubVideo.tsx"
      ],
      "evidence": [
        "PhilosophyPane.tsx:124-126 and :165-167 use `video.play().catch(() => ...)` but only remove listeners; no logging/telemetry.",
        "VideoEditModeDisplay.tsx:161 uses `video.play().catch(() => {})` with fully empty catch.",
        "HoverScrubVideo.tsx:192 calls `videoRef.current?.play()` without handling returned promise rejection; related file also uses ignored catches in load paths (:180-182, :205-207)."
      ],
      "suggestion": "Create a shared `safePlay(video, context)` helper that catches rejections and routes them to `handleError` (showToast false) so autoplay-policy/device failures are traceable and consistent.",
      "confidence": "medium",
      "impact_scope": "subsystem",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "async_error_channel_drift"
    },
    {
      "dimension": "error_consistency",
      "identifier": "optimistic_cache_failure_handling_diverges",
      "summary": "Similar optimistic-update failures are logged in one hook and ignored in another",
      "related_files": [
        "src/shared/components/ImageGenerationForm/hooks/referenceUpload/useStyleReferenceUploadHandler.ts",
        "src/shared/components/ImageGenerationForm/hooks/referenceUpload/useResourceSelectHandler.ts"
      ],
      "evidence": [
        "useStyleReferenceUploadHandler.ts:235-245 wraps optimistic cache update in catch that intentionally ignores the error.",
        "useResourceSelectHandler.ts:162-174 performs a comparable optimistic cache update but reports failures through `handleError` with explicit context.",
        "Both paths affect the same project-image-settings cache and reference workflows, but produce different observability behavior on failure."
      ],
      "suggestion": "Unify optimistic cache error policy across both handlers: either log all best-effort failures with `showToast:false` or encapsulate both in a shared helper that enforces one strategy.",
      "confidence": "high",
      "impact_scope": "module",
      "fix_scope": "multi_file_refactor",
      "root_cause_cluster": "silent_fallback_over_logging"
    }
